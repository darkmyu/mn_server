// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["strictUndefinedChecks"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  GOOGLE
  NAVER
  KAKAO
}

enum Species {
  DOG
  CAT
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id         Int      @id @default(autoincrement())
  email      String?
  nickname   String   @db.VarChar(30)
  username   String   @unique @db.VarChar(30)
  provider   Provider
  providerId String   @map("provider_id")
  thumbnail  String?
  about      String?  @db.VarChar(1000)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  animals              Animal[]
  photos               Photo[]
  photoLikes           PhotoLike[]
  followers            UserFollow[]   @relation("user_followings")
  followings           UserFollow[]   @relation("user_followers")
  photoComments        PhotoComment[] @relation("photo_comment_author")
  photoMentionComments PhotoComment[] @relation("photo_comment_mention")

  @@map("users")
}

model UserFollow {
  followerId  Int @map("follower_id")
  followingId Int @map("following_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  follower  User @relation("user_followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("user_followings", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("user_follows")
}

model Animal {
  id      Int @id @default(autoincrement())
  userId  Int @map("user_id")
  breedId Int @map("breed_id")

  name      String   @db.VarChar(30)
  gender    Gender
  birthday  DateTime @db.Timestamptz()
  thumbnail String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  breed Breed @relation(fields: [breedId], references: [id])

  photoAnimals PhotoAnimal[]

  @@map("animals")
}

model Breed {
  id        Int      @id @default(autoincrement())
  name      String
  species   Species
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  animals Animal[]

  @@map("breeds")
}

model Tag {
  id Int @id @default(autoincrement())

  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  photoTags PhotoTag[]

  @@map("tags")
}

model Photo {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")

  title       String?  @db.VarChar(100)
  description String?  @db.VarChar(1000)
  likes       Int      @default(0)
  score       Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  photoTags     PhotoTag[]
  photoImage    PhotoImage?
  photoLikes    PhotoLike[]
  photoAnimals  PhotoAnimal[]
  photoComments PhotoComment[]

  @@index([score(sort: Desc), id(sort: Desc)])
  @@map("photos")
}

model PhotoTag {
  photoId Int @map("photo_id")
  tagId   Int @map("tag_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([photoId, tagId])
  @@map("photo_tags")
}

model PhotoImage {
  id      Int @id @default(autoincrement())
  photoId Int @unique @map("photo_id")

  path      String
  size      Int
  width     Int
  height    Int
  mimetype  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("photo_images")
}

model PhotoLike {
  userId  Int @map("user_id")
  photoId Int @map("photo_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([userId, photoId])
  @@map("photo_likes")
}

model PhotoAnimal {
  photoId  Int @map("photo_id")
  animalId Int @map("animal_id")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  photo  Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@id([photoId, animalId])
  @@map("photo_animals")
}

model PhotoComment {
  id        Int  @id @default(autoincrement())
  userId    Int  @map("user_id")
  photoId   Int  @map("photo_id")
  parentId  Int? @map("parent_id")
  mentionId Int? @map("mention_id")

  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user    User           @relation("photo_comment_author", fields: [userId], references: [id], onDelete: Cascade)
  photo   Photo          @relation(fields: [photoId], references: [id], onDelete: Cascade)
  parent  PhotoComment?  @relation("photo_comment_replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies PhotoComment[] @relation("photo_comment_replies")
  mention User?          @relation("photo_comment_mention", fields: [mentionId], references: [id], onDelete: SetNull)

  @@map("photo_comments")
}
